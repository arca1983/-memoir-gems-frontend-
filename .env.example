# ─────────────────────────────────────────────
# Memoir Gems Frontend — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — Claude AI chatbot (optional, falls back to FAQ-only mode)
ANTHROPIC_API_KEY=sk-ant-...

# Resend — transactional email (optional, order/contact notifications)
RESEND_API_KEY=re_...

# ─────────────────────────────────────────────
# Where to find these values:
#
# Supabase: https://supabase.com/dashboard → your project → Settings → API
#   - NEXT_PUBLIC_SUPABASE_URL    = Project URL
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY = anon / public key
#   - SUPABASE_SERVICE_ROLE_KEY   = service_role key (keep secret!)
#
# Anthropic: https://console.anthropic.com → API Keys
#
# Resend: https://resend.com/api-keys
#
# Vercel: add these in Project → Settings → Environment Variables
# ─────────────────────────────────────────────

# UploadThing — real photo uploads on /en/order (required for photo capture to work)
# Reuse the SAME token already configured on the admin backend project — it's
# the same UploadThing account, so files from either app land in the same place.
UPLOADTHING_TOKEN=your-uploadthing-token-here

# Stripe / PayPal — optional. If unset, /en/order falls back to a "we'll email
# you a payment link" request flow instead of taking payment immediately.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_PAYPAL_CLIENT_ID=...
